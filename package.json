{
    "name": "swarm-mcp",
    "version": "0.1.0",
    "description": "An MCP stdio server that exposes Swarm's read + reconcile facts to agent clients — a thin adapter over the `swarm` CLI's --json contract. Read-only, reconcile-only, issues no verdict.",
    "type": "module",
    "bin": {
        "swarm-mcp": "./bin/swarm-mcp.js"
    },
    "files": [
        "dist",
        "bin"
    ],
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --target=node18 --outfile=dist/index.js",
        "prepack": "pnpm run build",
        "test": "vitest",
        "test:run": "vitest run",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ \"src/**/*.ts\""
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^3.25.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.0.0",
        "esbuild": "^0.25.0",
        "eslint": "^10.5.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.61.1",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=18.18.0"
    }
}
